{
  "name": "reviewer",
  "description": "Code review agent — analyzes implementations for correctness, security, and maintainability.",
  "prompt": "file://agents/reviewer.md",
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "url": "https://knowledge-mcp.global.api.aws",
      "type": "http",
      "disabled": false
    },
    "context7": {
      "command": "npx",
      "timeout": 200000,
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "*"
      ]
    }
  },
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "@builtin",
    "@aws-knowledge-mcp-server",
    "@context7"
  ],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python .kiro/hooks/validate-environment.py",
        "description": "Check required tools are installed"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python .kiro/hooks/git-context.py",
        "description": "Inject git status into context"
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python .kiro/hooks/config-drift-guard.py",
        "description": "Block writes to steering/skills/agents without approval"
      },
      {
        "matcher": "execute_bash",
        "command": "python .kiro/hooks/enforce-timeouts.py",
        "description": "Block test/build commands that have no timeout — prevents agent hang"
      }
    ],
    "stop": [
      {
        "command": "python .kiro/hooks/flywheel-log.py",
        "description": "Log turn summary for flywheel analysis"
      }
    ]
  },
  "toolsSettings": {},
  "model": "claude-opus-4.6"
}
