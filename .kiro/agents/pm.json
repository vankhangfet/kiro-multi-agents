{
  "name": "pm",
  "description": "Product Manager agent — elicits requirements using the AWS AI Development Lifecycle, writes a PRD, then dispatches the architect to design and implement.",
  "prompt": "file://agents/pm.md",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "timeout": 200000,
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "*"
      ]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "autoApprove": [
        "*"
      ]
    }
  },
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "@builtin",
    "@context7",
    "@deepwiki"
  ],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python .kiro/hooks/validate-environment.py",
        "description": "Check required tools are installed"
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python .kiro/hooks/check-secrets.py",
        "description": "Block writes containing secrets or API keys"
      },
      {
        "matcher": "fs_write",
        "command": "python .kiro/hooks/config-drift-guard.py",
        "description": "Block writes to steering/skills/agents without approval"
      }
    ],
    "stop": [
      {
        "command": "python .kiro/hooks/flywheel-log.py",
        "description": "Log turn summary for flywheel analysis"
      }
    ]
  },
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "architect",
        "coder",
        "docs"
      ],
      "trustedAgents": [
        "architect",
        "coder",
        "docs"
      ]
    }
  },
  "model": "claude-opus-4.7"
}
